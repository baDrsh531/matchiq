# Example environment variables for MatchIQ
# Copy this file to `.env` and fill the values locally. NEVER commit real keys.

# API-Football: sign up at https://www.api-football.com/ to obtain your key
API_FOOTBALL_KEY=
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io

# Gemini (LLM): create a key via Google Cloud / Vertex AI (or your LLM provider)
# Used for generating match and player reports
GEMINI_API_KEY=

# Optional: local DB path (default used by the app if omitted)
DATABASE_URL=sqlite:///data/matchiq.db
