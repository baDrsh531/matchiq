# --- Secrets : ne jamais commiter ---
# Regle large volontairement : tout fichier d'environnement est exclu,
# seul .env.example (sans valeurs) fait exception.
.env
.env.*
*.env
!.env.example
secrets.*
credentials.*
service-account*.json
*.pem
*.key
*.p12
*.pfx

# --- Python ---
__pycache__/
*.pyc
.venv/
venv/
*.egg-info/
.pytest_cache/

# --- Rapports de couverture (artefacts, jamais commites) ---
.coverage
.coverage.*
coverage.xml
htmlcov/

# --- Donnees applicatives (cache API + base locale) ---
# `data/` est le cache de travail local : volumineux, mouvant, jamais commite.
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep
data/matchiq.db
*.db
*.sqlite3

# `demo_data/` est l'exception assumee : jeu reduit et fige (3 matchs) servi
# par l'instance de demonstration publique, qui n'a aucun acces reseau.
!demo_data/
!demo_data/**

# --- Frontend ---
node_modules/
frontend/dist/
frontend/build/

# --- Outillage local ---
.history/
.vscode/
.idea/
